# Credenciais do Supabase (nuvem + login).
# Copie este arquivo para ".env" (mesma pasta) e preencha com os seus valores.
# Você encontra estes valores no painel do Supabase em:
#   Project Settings > API
#
# Sem estes valores, o sistema continua funcionando 100% local (sem login).

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# URL pública do sistema (usada nos links compartilhados da Agenda)
VITE_APP_URL=https://campanha.space
